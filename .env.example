# ─────────────────────────────────────────────────────────────────────────
# estoque.autos — variáveis de ambiente (template). Copie para .env.local e
# preencha. NENHUMA destas é segredo: a publishable key e a URL já vão para o
# browser, e APP_URL é público. (O .env.local fica fora do git.)
# ─────────────────────────────────────────────────────────────────────────

# Supabase — Project URL. Dashboard > Project Settings > Data API.
# Forma: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Supabase — publishable key (substitui a antiga anon JWT). Projetos de 2026
# entregam só esta (sb_publishable_...). É PÚBLICA; o RLS é a fronteira de
# segurança. O nome da var continua *_ANON_KEY por compat com @supabase/ssr.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# URL canônica do app/admin. Em DEV use http://localhost:3000; em PROD use o
# host do app (ex.: https://app.estoque.autos). Usado só em código server
# (emailRedirectTo, robots, sitemap, canonical/OG). Em prod o valor vem das
# `vars` do wrangler.jsonc no runtime do Worker.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Build-time only (opcional, recomendado p/ prod) ───────────────────────
# Mantém os payloads de Server Actions decifráveis entre instâncias do Worker
# (evita "Failed to find Server Action" sob escala horizontal). Gere com:
#   openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# ── SECRETS (server-only; na Cloudflare entram como SECRET, nunca em vars) ──

# Supabase secret key (sb_secret_...). Usada SÓ pelo webhook do Stripe e por
# scripts de seed/cron (caminhos sem usuário logado — ver lib/supabase/admin).
SUPABASE_SECRET_KEY="sb_secret_..."

# Stripe — Dashboard > Developers > API keys (modo teste: sk_test_...).
STRIPE_SECRET_KEY="sk_test_..."

# Stripe — assinatura do webhook. Em prod: Dashboard > Webhooks > endpoint
# /api/stripe/webhook. Em dev: `stripe listen --forward-to
# localhost:3000/api/stripe/webhook` imprime um whsec_... (opcional — a página
# de sucesso tem fallback síncrono que confirma a sessão sem webhook).
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe — price ids recorrentes dos planos (mensal e anual). Gerados por:
#   npx tsx scripts/stripe-setup.ts
STRIPE_PRICE_BASICO_MENSAL="price_..."
STRIPE_PRICE_BASICO_ANUAL="price_..."
STRIPE_PRICE_PRO_MENSAL="price_..."
STRIPE_PRICE_PRO_ANUAL="price_..."

# ── Cloudflare for SaaS — domínio próprio por loja (OPCIONAL) ──────────────
# Quando presentes, ao salvar um domínio próprio o app registra um "custom
# hostname" na zona do app (emite o certificado e roteia o host para o Worker).
# Sem eles, o fluxo segue só com instruções de DNS + verificação por DNS/HTTP
# (o lojista aponta o CNAME e o app valida o apontamento). É graceful: a
# ausência NÃO quebra o cadastro de domínio.
#
# API token com permissão "SSL and Certificates: Edit" na zona (server-only).
# CLOUDFLARE_API_TOKEN=""
# Zona (domínio do app) onde os custom hostnames são criados.
# Dashboard > Overview da zona > API > Zone ID.
# CLOUDFLARE_ZONE_ID=""
